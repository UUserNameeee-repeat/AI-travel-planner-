{
  "budget_test_cases": [
    {
      "test_id": "B001",
      "name": "成都4日5000元2人舒适游",
      "input": {
        "destination": "成都",
        "days": 4,
        "total_budget": 5000,
        "travelers": 2,
        "accommodation_level": "standard"
      },
      "expected": {
        "per_person_daily": 625,
        "budget_level": "comfortable",
        "accommodation_range": [1200, 1800],
        "food_range": [1000, 1500],
        "total_should_equal": 5000
      }
    },
    {
      "test_id": "B002",

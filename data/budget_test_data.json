        "accommodation_level": "budget"
      },
      "expected": {
        "per_person_daily": 1000,
        "budget_level": "comfortable",
        "accommodation_range": [800, 1200],
        "food_range": [600, 900],
        "total_should_equal": 3000
      }
    },
    {
